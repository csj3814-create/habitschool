{
  "name": "habit-contracts",
  "version": "1.0.0",
  "description": "HaBit (HBT) smart contracts for BNB Smart Chain",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "export:abi": "node scripts/export-abi.js",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network bscTestnet",
    "deploy:mainnet": "npx hardhat run scripts/deploy.js --network bsc",
    "dress-rehearsal:testnet": "npx hardhat run scripts/dress-rehearsal.js --network bscTestnet",
    "verify:testnet": "npx hardhat verify --network bscTestnet",
    "verify:mainnet": "npx hardhat verify --network bsc"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.0"
  }
}
