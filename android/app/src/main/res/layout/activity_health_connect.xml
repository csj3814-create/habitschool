<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/habitschool_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_native_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/native_health_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/native_health_title"
                android:textColor="@color/habitschool_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/native_health_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/native_health_permission_copy"
                android:textColor="@color/habitschool_text_muted"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/native_health_progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/native_health_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/native_health_grant_permission" />

            <Button
                android:id="@+id/native_health_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/native_health_open_exercise" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
