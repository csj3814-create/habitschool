{
  "name": "habitschool",
  "version": "1.0.0",
  "description": "건강 습관을 기록하고 포인트를 모으는 **Move-to-Earn(M2E)** PWA 앱입니다.",
  "main": "sw.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:emulator": "firebase emulators:exec --only firestore --project habitschool-staging \"npx vitest run tests/firestore-privacy-rules.emulator.test.js\"",
    "build:en": "node scripts/generate-en-entry.js",
    "check:en": "node scripts/generate-en-entry.js --check",
    "mainnet:config:check": "node scripts/sync-mainnet-config.js --check",
    "mainnet:config:sync": "node scripts/sync-mainnet-config.js",
    "mainnet:config:enable": "node scripts/sync-mainnet-config.js --enable-prod-mainnet",
    "deploy": "firebase deploy --only hosting",
    "emulators": "firebase emulators:start --project staging",
    "deploy:staging": "firebase deploy --project staging --only hosting,functions,firestore:rules,firestore:indexes,storage",
    "deploy:staging:hosting": "firebase deploy --project staging --only hosting",
    "deploy:prod": "firebase deploy --project prod --only hosting,functions,firestore:rules,firestore:indexes,storage",
    "deploy:prod:hosting": "firebase deploy --project prod --only hosting"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@firebase/rules-unit-testing": "3.0.2",
    "firebase": "10.8.0",
    "sharp": "^0.34.5",
    "vitest": "^4.0.18"
  }
}
