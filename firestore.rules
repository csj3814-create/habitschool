rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 헬퍼 함수: 로그인한 사용자인지 확인
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 헬퍼 함수: 본인인지 확인
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // 헬퍼 함수: 관리자 권한 확인 (Firestore admins 컬렉션 기반)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 헬퍼 함수: 공유 설정 검증
    function isValidShareSettings(settings) {
      return settings is map
          && settings.keys().hasOnly(['hideIdentity', 'hideDate', 'hideDiet', 'hideExercise', 'hidePoints', 'hideMind', 'hideMindText'])
          && (!('hideIdentity' in settings) || settings.hideIdentity is bool)
          && (!('hideDate' in settings) || settings.hideDate is bool)
          && (!('hideDiet' in settings) || settings.hideDiet is bool)
          && (!('hideExercise' in settings) || settings.hideExercise is bool)
          && (!('hidePoints' in settings) || settings.hidePoints is bool)
          && (!('hideMind' in settings) || settings.hideMind is bool)
          && (!('hideMindText' in settings) || settings.hideMindText is bool);
    }
    
    // 헬퍼 함수: 데이터 검증
    function isValidDailyLog() {
      let data = request.resource.data;
      return data.userId is string
          && data.date is string
          && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && data.date >= '2024-01-01'
          && data.date <= '2030-12-31'
          && (!('userName' in data) || data.userName is string)
          && (!('metrics' in data) || data.metrics is map)
          && (!('diet' in data) || data.diet is map)
          && (!('exercise' in data) || data.exercise is map)
          && (!('sleepAndMind' in data) || data.sleepAndMind is map)
          && (!('shareSettings' in data) || isValidShareSettings(data.shareSettings));
    }
    
    // 헬퍼 함수: 사용자 필드 화이트리스트
    function isAllowedUserField() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['email', 'displayName', 'customDisplayName', 'photoURL', 'createdAt',
                    'walletAddress', 'walletCreatedAt', 'encryptedKey', 'walletIv', 'walletVersion',
                    'oldWalletAddress', 'encryptedWallet',
                    'activeChallenge', 'activeChallenges', 'milestones', 'settings',
                    'lastLogin', 'fcmToken', 'healthProfile', 'inbodyData',
                    'dietAnalysis', 'exerciseAnalysis', 'sleepAndMind', 'blockedUsers',
                    'weeklyMissionData', 'missionHistory', 'missionStreak', 'missionLevel',
                    'missionBadges', 'selectedMissions', 'missionLevelUpDate',
                    'referralCode', 'currentStreak', 'onboardingComplete', 'friends',
                    'chatbotLinkCode', 'chatbotLinkCodeExpiresAt', 'chatbotLinkCodeGeneratedAt',
                    'chatbotLinkCodeLastUsedAt']);
    }
    
    // ===== Users Collection =====
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // 사용자가 직접 수정 가능한 필드 제한 (hbtBalance, totalHbtEarned, coins는 Cloud Functions만 수정 가능)
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['hbtBalance', 'totalHbtEarned', 'coins']))
        && isAllowedUserField();
      allow delete: if isOwner(userId) || isAdmin();
      // ===== InBody History Subcollection =====
      match /inbodyHistory/{recordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ===== Blood Test Results Subcollection =====
      match /bloodTests/{testId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
    
    // ===== Daily Logs Collection =====
    match /daily_logs/{logId} {
      // 갤러리: 비로그인 사용자도 읽기 허용 (접근성)
      allow read: if true;
      
      allow create: if isSignedIn() 
                    && isValidDailyLog()
                    && request.resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (isOwner(resource.data.userId) 
          && isValidDailyLog()
          && request.resource.data.userId == resource.data.userId)
        ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']))
      );
      
      allow update: if isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // ===== Health Profiles Collection =====
    match /health_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }
    
    // ===== Reactions Collection =====
    match /reactions/{reactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() 
                    && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }
    
    // ===== Notifications Collection =====
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.postOwnerId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['postOwnerId', 'type'])
                    && request.resource.data.postOwnerId != request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.postOwnerId == request.auth.uid;
    }

    // ===== Friendships Collection =====
    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create, update, delete: if false;
    }
    
    // ===== Admin Feedback Collection =====
    match /admin_feedback/{feedbackId} {
      allow read: if isSignedIn() 
                  && (resource.data.targetUserId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    
    // ===== Admin Messages Collection =====
    match /admin_messages/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    // ===== Admins Collection =====
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ===== Blockchain Transactions Collection =====
    match /blockchain_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ===== Mining Rate History Collection =====
    match /mining_rate_history/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ===== Monthly Rewards Collection =====
    match /monthly_rewards/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ===== Reports Collection (UGC 신고) =====
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // meta 컬렉션: 서버에서 계산한 통계 (communityStats 등)
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 월별 커뮤니티 통계 아카이브 (이전 달 현황 기록)
    match /communityStats_archive/{monthId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ===== Email Logs Collection (관리자 읽기 전용, 쓰기는 CF Admin SDK만)
    match /emailLogs/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ===== Social Challenges Collection =====
    match /social_challenges/{challengeId} {
      allow read: if isSignedIn() &&
        (request.auth.uid in resource.data.participants ||
         request.auth.uid in resource.data.invitees);
      allow create: if isSignedIn() &&
        request.resource.data.creatorId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // 기본 규칙: 모든 접근 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
